generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
}


enum SubscriptionType {
  SIGNALS  // Accès calls + news, trade par soi-même
  MANAGED  // On trade à sa place
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum AffiliateStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── USERS ───────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String   @unique
  phone         String
  country       String   // Auto-détecté à l'inscription
  language      String   @default("FR")
  passwordHash  String
  role          Role     @default(CLIENT)

  // Confirmation email
  emailVerified Boolean  @default(false)
  emailCode     String?  // Code OTP
  emailCodeExp  DateTime? // Expiration du code

  // Essai gratuit
  trialEndsAt   DateTime? // Calculé à l'inscription (now + durée globale), modifiable par l'admin

  // Telegram
  telegramChatId String? @unique

  // Stripe
  stripeCustomerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscriptions   Subscription[]
  invoices        Invoice[]
  affiliate       Affiliate?      // Demande d'affiliation
  referredBy      Referral?       @relation("ReferredUser")    // Le parrainage qui l'a amené
  referrals       Referral[]      @relation("ReferrerUser")    // Ses filleuls
  managedAccount  ManagedAccount?
  notifications     Notification[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

// ─── ABONNEMENTS ─────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  type                 SubscriptionType
  status               SubscriptionStatus @default(ACTIVE)

  // Stripe
  stripeSubscriptionId String?  @unique
  stripePriceId        String?

  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime // = prochaine date de prélèvement
  cancelledAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
  commissions Commission[]

  @@map("subscriptions")
}

// ─── FACTURES ────────────────────────────────────────────

model Invoice {
  id              String @id @default(cuid())
  userId          String
  subscriptionId  String
  invoiceNumber   String @unique // KDX-2026-001
  amount          Float  // en EUR
  plan            String // "Signals 1 month", "Managed 3 months"
  status          String @default("paid") // paid, refunded, disputed
  stripePaymentId String? // Stripe payment intent ID
  stripeReceiptUrl String? // URL du reçu Stripe

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ─── MANAGED TRADING ─────────────────────────────────────

model ManagedAccount {
  id             String @id @default(cuid())
  userId         String @unique
  platformName   String   // Nom de la plateforme (Binance, Bybit, etc.)
  apiKey         String   // Clé API (chiffrée en prod)
  apiSecret      String   // Secret API (chiffré en prod)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("managed_accounts")
}

// ─── CALLS (SIGNAUX) ────────────────────────────────────

model TradingPair {
  id     String @id @default(cuid())
  base   String // ex: ETH
  quote  String // ex: USDT
  active Boolean @default(true)

  calls Call[]

  @@unique([base, quote])
  @@map("trading_pairs")
}

model Call {
  id            String  @id @default(cuid())
  tradingPairId String
  entryMin      Float   // Montant d'entrée minimum
  entryMax      Float   // Montant d'entrée maximum
  stopLoss      Float
  active        Boolean @default(true) // Activé/désactivé par l'admin

  telegramSent  Boolean @default(false) // Message Telegram envoyé ?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tradingPair TradingPair  @relation(fields: [tradingPairId], references: [id])
  targets     CallTarget[]

  @@map("calls")
}

model CallTarget {
  id       String  @id @default(cuid())
  callId   String
  rank     Int     // 1 = TP1 (obligatoire), 2 = TP2, etc.
  price    Float
  reached  Boolean @default(false) // TP atteint ou non

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@unique([callId, rank])
  @@map("call_targets")
}

// ─── NEWS ────────────────────────────────────────────────

model News {
  id           String  @id @default(cuid())
  // Default (EN)
  title        String
  description  String
  // French
  titleFr      String?
  descriptionFr String?
  // Spanish
  titleEs      String?
  descriptionEs String?
  // Turkish
  titleTr      String?
  descriptionTr String?

  imageUrl     String? // Legacy single image (kept for backward compat)
  active       Boolean @default(true)

  telegramSent Boolean @default(false)

  images    NewsImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news")
}

model NewsImage {
  id       String @id @default(cuid())
  newsId   String
  url      String
  sortOrder Int   @default(0)
  news     News   @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@map("news_images")
}

// ─── AFFILIATION / PARRAINAGE ────────────────────────────

model Affiliate {
  id          String          @id @default(cuid())
  userId      String          @unique
  status      AffiliateStatus @default(PENDING)
  promoCode   String?         @unique // Généré à l'approbation
  referralLink String?        // Généré à l'approbation

  approvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissions        Commission[]
  withdrawalRequests WithdrawalRequest[]

  @@map("affiliates")
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String   // L'affilié qui a parrainé
  referredUserId String   @unique // Le filleul

  createdAt DateTime @default(now())

  // Anti-fraud tracking
  referrerIp   String?  // IP du parrain au moment du parrainage
  referredIp   String?  // IP du filleul à l'inscription

  referrer     User         @relation("ReferrerUser", fields: [referrerId], references: [id])
  referredUser User         @relation("ReferredUser", fields: [referredUserId], references: [id])
  commissions  Commission[]

  @@map("referrals")
}

// ─── COMMISSIONS ────────────────────────────────────────

model Commission {
  id               String   @id @default(cuid())
  affiliateId      String   // L'affilié qui reçoit la commission
  referralId       String   // Le parrainage lié
  subscriptionId   String   // L'abonnement du filleul
  invoiceId        String?  // La facture liée

  grossAmount      Float    // Montant brut du paiement
  stripeFeesAmount Float    // Frais Stripe déduits
  netAmount        Float    // Montant net (après frais Stripe)
  commissionRate   Float    // Taux de commission (ex: 0.10 = 10%)
  commissionAmount Float    // Montant de la commission

  status           String   @default("PENDING") // PENDING, REVIEW, AVAILABLE, PAID, CANCELLED

  // Anti-fraud
  flagged          Boolean  @default(false)
  flagReason       String?  // "same_ip", "similar_email", "same_country_short_delay"
  reviewedByAdmin  Boolean  @default(false)

  // Tracking
  maturesAt        DateTime // Date à laquelle la commission devient AVAILABLE
  stripePaymentId  String?  // Pour vérifier le paiement côté Stripe

  cancelledAt      DateTime?
  cancelReason     String?  // "refund", "dispute", "admin", "fraud"

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  affiliate    Affiliate    @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referral     Referral     @relation(fields: [referralId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("commissions")
}

// Paliers de commissions définis par l'admin (legacy — garder pour compatibilité)
model CommissionTier {
  id            String @id @default(cuid())
  minReferrals  Int
  maxReferrals  Int?
  amount        Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("commission_tiers")
}

// ─── TUTORIELS & FAQ ─────────────────────────────────────

model Faq {
  id       String @id @default(cuid())
  question String
  answer   String
  sortOrder Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model Tutorial {
  id          String @id @default(cuid())
  title       String
  videoUrl    String
  description String?
  sortOrder   Int    @default(0)
  isManagedGuide Boolean @default(false) // Vidéo guide pour le managed trading

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tutorials")
}

// ─── NOTIFICATIONS ───────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String?  // null = broadcast to all
  title     String
  message   String
  type      String   @default("info") // info, call, news, system
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ─── RETRAITS AFFILIÉS ───────────────────────────────────

model WithdrawalRequest {
  id              String  @id @default(cuid())
  affiliateId     String
  amount          Float
  paymentMethod   String  // "iban", "paypal", "mobile_money"
  paymentDetails  String  // IBAN, email PayPal, numéro mobile money
  status          String  @default("PENDING") // PENDING, APPROVED, COMPLETED, REJECTED
  adminNote       String?
  processedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("withdrawal_requests")
}

// ─── PARAMÈTRES GLOBAUX (admin) ──────────────────────────

model AppSettings {
  id                      String @id @default("singleton")
  trialDurationDays       Int    @default(7)
  telegramBotToken        String?
  telegramBotUsername     String?  // e.g. "KodexBot" — used to generate connect links
  telegramChannelId       String?

  // Commission settings
  commissionRate          Float  @default(0.10) // 10% par défaut
  commissionSecurityDays  Int    @default(30)   // Période de sécurité en jours
  commissionMonthlyCap    Float  @default(5000) // Plafond mensuel par affilié en EUR

  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
